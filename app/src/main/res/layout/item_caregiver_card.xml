<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar circle with first initial -->
        <TextView
            android:id="@+id/textCaregiverInitial"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="C"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/circle_avatar_bg"
            android:layout_marginEnd="14dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textCaregiverName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Caregiver Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <TextView
                android:id="@+id/textCaregiverEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="email@example.com"
                android:textSize="12sp"
                android:textColor="@color/text_gray"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/textCaregiverPermission"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View only"
                android:textSize="11sp"
                android:textColor="@color/mint_green_dark"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnRevokeCaregiver"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Remove"
            android:textSize="12sp"
            android:backgroundTint="@color/bg_light"
            android:textColor="#D32F2F"
            android:strokeColor="#D32F2F"
            android:strokeWidth="@dimen/stroke_width_thin"            android:paddingHorizontal="10dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

    </LinearLayout>
</androidx.cardview.widget.CardView>