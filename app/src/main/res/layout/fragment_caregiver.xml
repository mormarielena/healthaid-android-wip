<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <ScrollView
        android:id="@+id/scrollCaregiver"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@android:id/empty"
        android:clipToPadding="false"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Caregivers"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="People who can view your medication schedule"
                android:textSize="13sp"
                android:textColor="@color/text_gray"
                android:layout_marginBottom="24dp" />

            <ProgressBar
                android:id="@+id/progressBarCaregiver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textViewCaregiverEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No caregivers yet.\nTap + to invite someone by email."
                android:textAlignment="center"
                android:textSize="14sp"
                android:textColor="@color/text_gray"
                android:lineSpacingExtra="4dp"
                android:paddingTop="40dp"
                android:visibility="gone" />

            <!-- Patient pill monitoring section (visible in caregiver mode) -->
            <TextView
                android:id="@+id/textPatientPillsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Patient's medications today"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressPatientPills"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/containerPatientPills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:visibility="gone" />

            <!-- My caregivers section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="People monitoring me"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="8dp" />

            <!-- Caregiver cards injected here -->
            <LinearLayout
                android:id="@+id/containerCaregivers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddCaregiver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Invite caregiver"
        app:backgroundTint="@color/purple_accent"
        app:tint="@color/white"
        app:elevation="4dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

</RelativeLayout>